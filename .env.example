# ============================================================
# ZUA 招生咨询助手 - 配置文件
# 复制本文件为 .env 并填写实际值即可运行
# ============================================================

# ============================================================
# 【必填】大模型 API 配置（通义千问 / 兼容 OpenAI 格式的 API）
# ============================================================
# 从阿里云 DashScope 获取 API Key: https://dashscope.console.aliyun.com/
ZUA_API_KEY=your-api-key-here
ZUA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# 【可选】MySQL 配置（历年录取分数查询，不配置则跳过分数查询）
# ============================================================
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名
ZUA_MYSQL_URI=

# ============================================================
# 【可选】Neo4j 配置（知识图谱查询，不配置则跳过图谱查询）
# ============================================================
ZUA_NEO4J_URI=bolt://localhost:7687
ZUA_NEO4J_USER=neo4j
ZUA_NEO4J_PASSWORD=

# ============================================================
# 【可选】管理面板密码（留空则不启用管理面板）
# ============================================================
ZUA_ADMIN_PASSWORD=
